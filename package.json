{
  "name": "causal-tree-decomposition",
  "version": "1.0.0",
  "description": "A standalone probability engine that decomposes complex predictions into causal trees using Bayesian AND/OR logic. Zero dependencies.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "causal-inference",
    "probability",
    "bayesian",
    "prediction-markets",
    "thesis-engine",
    "decision-tree",
    "typescript",
    "kalshi",
    "polymarket",
    "risk-analysis"
  ],
  "author": "SimpleFunctions <hello@simplefunctions.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spfunctions/causal-tree-decomposition.git"
  },
  "homepage": "https://github.com/spfunctions/causal-tree-decomposition#readme",
  "bugs": {
    "url": "https://github.com/spfunctions/causal-tree-decomposition/issues"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
